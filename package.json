{
  "name": "akarisub",
  "version": "1.9.0",
  "description": "libass Subtitle Renderer and Parser library for browsers",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/ts/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/ts/index.d.ts"
    },
    "./worker": {
      "import": "./dist/akarisub-worker.js"
    }
  },
  "files": [
    "dist/COPYRIGHT",
    "dist/default.woff2",
    "dist/akarisub*",
    "dist/ts",
    "dist/index.js",
    "src/ts"
  ],
  "scripts": {
    "build:wasm": "make worker",
    "build:ts": "tsgo",
    "build:bundle": "bun build.ts",
    "build": "bun run build:wasm && bun run build:ts && bun run build:bundle",
    "typecheck": "tsc --noEmit",
    "format": "bun run prettier . --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altqx/akarisub.git"
  },
  "keywords": [
    "libass",
    "subtitle",
    "wasm",
    "emscripten"
  ],
  "author": "altqx",
  "contributors": [
    "ThaUnknown",
    "SubtitlesOctopus Contributors"
  ],
  "license": "LGPL-2.1-or-later AND (FTL OR GPL-2.0-or-later) AND MIT AND MIT-Modern-Variant AND ISC AND NTP AND Zlib AND BSL-1.0",
  "bugs": {
    "url": "https://github.com/altqx/akarisub/issues"
  },
  "homepage": "https://github.com/altqx/akarisub",
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/emscripten": "^1.41.5",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "@webgpu/types": "^0.1.69",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
