{
  "name": "akarisub",
  "version": "0.1.0",
  "author": "altqx",
  "license": "MIT",
  "description": "AkariSub",
  "keywords": [
    "akarisub",
    "ass",
    "subtitle",
    "wasm",
    "rust",
    "rendering",
    "video",
    "player"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pkg": {
      "import": "./pkg/akarisub.js",
      "types": "./pkg/akarisub.d.ts"
    },
    "./pkg-bundler": {
      "import": "./pkg-bundler/akarisub.js",
      "types": "./pkg-bundler/akarisub.d.ts"
    }
  },
  "files": [
    "dist",
    "pkg",
    "pkg-bundler",
    "src/wrapper.ts"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build --target web --out-dir pkg",
    "build:wasm:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler",
    "build:wasm:release": "wasm-pack build --release --target web --out-dir pkg && wasm-pack build --release --target bundler --out-dir pkg-bundler",
    "build:ts": "tsgo",
    "build": "bun run build:wasm:release && bun run build:ts",
    "clean": "rm -rf dist pkg pkg-bundler target",
    "test": "cargo test",
    "format": "cargo fmt && prettier . --write"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260306.1",
    "@webgpu/types": "^0.1.69",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=18"
  }
}